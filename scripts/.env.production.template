# GreenMarket Production Environment Configuration
# Copy to /etc/greenmarket/.env on the production server
# Set permissions: chmod 600 /etc/greenmarket/.env

# ==========================================
# NODE CONFIGURATION
# ==========================================
NODE_ENV=production
PORT=5000

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=greenmarket_user
DB_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
DB_NAME=greenmarket_prod

# ==========================================
# AUTHENTICATION
# ==========================================
# Generate a secure JWT secret with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_TO_SECURE_SECRET

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
FRONTEND_URL=https://umc-green-project-prd-app-01.oit.umn.edu

# Alternative if frontend is hosted separately:
# FRONTEND_URL=https://umc-green.vercel.app

# ==========================================
# LOGGING (Optional)
# ==========================================
# LOG_LEVEL=info

# ==========================================
# EMAIL CONFIGURATION (For future use)
# ==========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# ==========================================
# CLOUDINARY (For image uploads - optional)
# ==========================================
# CLOUDINARY_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret
